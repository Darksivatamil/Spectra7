# Spectra7 Configuration - copy to .env and fill in real values
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here
# Run `python -c "import os; from dotenv import load_dotenv; load_dotenv(); from utils.crypto import encrypt_api_key; print(encrypt_api_key('<YOUR_KEY>'))"` after setting FERNET_KEY
ENCRYPTED_NVIDIA_KEY=your_encrypted_nvidia_key_here
# Flask session key - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_secret
# Single-password gate for the dashboard
DASHBOARD_PASSWORD=change_this_password
# Bind host (use 0.0.0.0 only if behind reverse proxy + firewall)
HOST=127.0.0.1
PORT=5000
# Optional: comma-separated allowlist of target phone numbers (E.164 without +)
# ALLOWLIST_TARGETS=919876543210,919812345678
MAX_PER_TARGET_PER_DAY=250
# Concurrency engine: auto|threaded|async|rq
CONCURRENCY_MODE=auto
# REDIS_URL=redis://localhost:6379/0
